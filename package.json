{
  "name": "emojicon",
  "version": "1.0.0-beta.4",
  "private": true,
  "description": "Cloudflare Worker that takes a standard unicode emoji and returns it as an SVG for use as favicons or CSS cursors",
  "homepage": "https://github.com/mikesprague/emojicon#readme",
  "bugs": {
    "url": "https://github.com/mikesprague/emojicon/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Michael Sprague",
    "email": "mikesprague@gmail.com"
  },
  "type": "module",
  "exports": "./src/index.js",
  "scripts": {
    "start": "npx wrangler dev",
    "deploy": "npx wrangler publish"
  },
  "devDependencies": {
    "cross-env": "10.1.0",
    "cz-git": "1.13.1",
    "oxfmt": "0.59.0",
    "oxlint": "1.73.0",
    "wrangler": "4.110.0"
  },
  "overrides": {},
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-git"
    }
  },
  "engines": {
    "node": ">= 24.x",
    "npm": ">= 11.x"
  },
  "volta": {
    "node": "26.4.0",
    "npm": "11.18.0"
  },
  "packageManager": "npm@11.18.0",
  "allowScripts": {
    "esbuild@0.28.1": true,
    "sharp@0.34.5": true,
    "fsevents@2.3.3": true,
    "workerd@1.20260701.1": true
  }
}
